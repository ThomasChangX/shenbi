{
  "genre": "战争史诗",
  "sub_genres": ["架空历史", "异世大陆", "穿越", "政治幻想"],
  "fatigue_words": [
    "突然", "猛地", "瞬间", "一股", "恐怖", "死死",
    "眼中闪过", "嘴角", "冷冷", "淡淡", "微微一笑",
    "心中一动", "暗道", "不由得", "显然", "似乎",
    "仿佛", "如同", "无比", "极致", "难以形容",
    "不可思议", "前所未有", "令人发指", "震惊",
    "愣住", "呆住", "不由得倒吸一口凉气"
  ],
  "audit_dimensions": [
    "character_consistency",
    "continuity",
    "dialogue_quality",
    "pacing",
    "anti_ai_flavor",
    "world_rules_compliance",
    "foreshadowing_tracking",
    "emotional_authenticity",
    "reader_pull",
    "prose_quality",
    "era_appropriateness",
    "motivation_plausibility",
    "pov_consistency",
    "sensitivity_check",
    "memo_compliance"
  ],
  "chapter_word": {
    "_convention": "起点中文网 平台默认值。default 为普通章字数，ceiling 为大章上限。floor = default，不可突破。",
    "default": 3000,
    "ceiling": 10000,
    "_chapter_count_formula": "expected_chapters = ceil(novel.target_words / chapter_word.default)。此值不存储在文件中，每次使用前动态计算。"
  },
  "pacing_rules": {
    "act_proportions": {
      "act1": "25%",
      "act2": "50%",
      "act3": "25%"
    }
  },
  "style_notes": "战争场面需兼具宏观视野与微观感受；政治思辨融入对话与行动，避免说教；幽默底色包裹严肃主题；Show/Don't Tell 比例 75/25"
}
