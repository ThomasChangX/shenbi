  "auditDimensions": {
    "antiAi": true,
    "character": true,
    "motivation": true,
    "pacing": true,
    "continuity": true,
    "foreshadowing": true,
    "sensitivity": true,
    "worldRules": true,
    "dialogue": true,
    "texture": false
