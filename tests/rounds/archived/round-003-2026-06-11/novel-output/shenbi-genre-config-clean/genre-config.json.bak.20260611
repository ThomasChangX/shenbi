  "audit_dimensions": {
    "架空历史": {
      "世界自洽性": "设定是否前后矛盾？历史逻辑是否自洽？",
      "文明质感": "社会结构、经济基础、文化习俗是否有厚度？",
      "权力逻辑": "统治阶级维护权力的手段是否可信？"
    },
    "异世大陆": {
      "规则一致性": "灵能/魔法系统的规则是否始终如一执行？",
      "地理真实性": "地理环境对文明形态的影响是否合理？",
      "多元文明": "不同势力/位面的文化是否真正各自独立发展？"
    },
    "战争史诗": {
      "军事逻辑": "战术选择是否符合双方实力和地形条件？",
      "代价展示": "战争是否有真实代价？胜利是否来之不易？",
      "后勤现实": "军队的物资、情报、动员是否被充分展示？"
