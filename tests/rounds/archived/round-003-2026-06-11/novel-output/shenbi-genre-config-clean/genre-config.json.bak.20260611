    "政治幻想": {
      "思想深度": "政治理念是否从具体社会矛盾中自然生长而非空降？",
      "组织逻辑": "革命组织的建设、分裂、团结是否有真实过程？",
      "阶级展示": "不同阶级的利益诉求和行为逻辑是否被准确呈现？",
      "路线斗争": "是否展现不同思想路线的真实交锋而非单一正确？"
    }
  },
  "pacing_rules": {
    "架空历史": {
      "开局节奏": "穿越初期需有3-5章展示认知磨合与生存压力，不可直奔爽点",
      "权力攀升": "每阶段权力/地位的提升必须对应同量级的代价或敌人升级",
      "信息释放": "世界观设定通过情节和冲突自然揭示，每章最多引入1个新设定概念"
    },
    "异世大陆": {
      "探索递进": "新地图/新位面的发现节奏应为每卷1-2个，每个需有充分展开",
      "修炼进度": "力量提升必须伴随对应的认知突破或道德抉择，不能仅靠资源堆砌",
      "神秘感维护": "每个揭开的谜底应引出更大的谜题，保持世界的神秘纵深"
    },
    "战争史诗": {
      "战争密度": "每30章至少1场完整战役描写，战役间隔用于恢复、建设和政治博弈",
      "胜负节奏": "每场胜利后必须有新困难出现，每场失败后必须有具体教训转化为战斗力",
      "视角切换": "每场战役至少展示3个层级视角（指挥决策层、基层官兵、后方民众）"
    },
    "穿越": {
      "金手指成长": "金手指的每次升级必须对应主角思想认知的一次跃升",
      "现代知识转化": "每20章最多引入1项现代知识的核心应用，须展示完整的试错过程",
      "身份焦虑": "每10章至少1段主角对自我身份的反思与挣扎"
    },
    "政治幻想": {
      "思想演进": "核心政治思想的形成需经历至少4个阶段（萌芽-实践-挫败-成熟）",
      "群众互动": "每10章至少1次与底层群众的具体深度交流，展示民心变化",
      "路线斗争": "全书至少3次不同思想路线之间的实质性辩论，不可简化为正邪对立"
    }
  },
  "integrity_constraints": {
    "灵能守恒": "任何灵能运用的描写必须在前后章节有能量来源和去向的说明",
    "知识对应": "任何新灵能能力的出现必须对应之前建立的知识积累",
    "殖民逻辑": "殖民体系的运作必须在经济、技术、制度三个层面同时展现，不能简化为纯军事压迫",
    "阶级流动": "所有跨阶级行为必须展示结构性阻力和代价",
    "参考坐标_毛泽东选集": "引用或化用的军事/政治思想的每一次应用必须对应具体的战场或社会实际条件，不能空降理论",
    "参考坐标_三体": "文明之间互动的逻辑必须严肃处理信任缺失和博弈复杂性，不能简单化为善意外交",
    "参考坐标_银河英雄传说": "战争政治的双层叙事（宏观战略+个体命运）必须在每个战役章节中同时体现"
