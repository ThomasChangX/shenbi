{
  "genre": "架空历史/战争史诗",
  "fatigue_words": {
    "forbidden": ["俊美", "剑眉星目", "邪魅一笑", "恐怖如斯", "倒吸一口凉气", "嘴角微掀", "美眸"],
    "discouraged": ["冷冷道", "冷哼一声", "不用说", "旋即", "顿时", "立刻", "忽然", "便"],
    "max_repeat_distance_chars": 2000
  },
  "audit_dimensions": {
    "era_consistency": {
      "enabled": true,
      "rules": ["无现代词汇（除主角内心独白外）", "武器和技术水平与架空中世纪/近代过渡期一致", "社会制度符合封建崩溃/复辟期特征"]
    },
    "military_accuracy": {
      "enabled": true,
      "rules": ["战术描写需有逻辑支撑", "兵力数字保持前后一致", "后勤补给不能凭空出现"]
    },
    "character_voice": {
      "enabled": true,
      "rules": ["每个角色有独特说话方式", "主角幽默自嘲语气需保持", "政委角色语言正式、有理论深度"]
    },
    "world_rule_adherence": {
      "enabled": true,
      "rules": ["灵能使用必须符合守恒律", "位面通道特性（时间流速、重力）始终一致", "阶级和种姓制度影响所有社会互动"]
    },
    "political_theme_tone": {
      "enabled": true,
      "rules": ["政治思想通过人物言行自然呈现，避免大段说教", "主角思想转变有阶段和触发事件，不突兀", "反面角色动机合理，不脸谱化"]
    }
  },
  "pacing_rules": {
    "daily_chapter_target": 3000,
    "action_scene_min_words": 500,
    "introspection_max_consecutive_chapters": 2,
    "required_elements_per_chapter": ["情节推进", "至少一个感官描写"],
    "cliffhanger_frequency": "每2-3章一次"
  },
  "platform_rules": {
    "sensitive_topics_handled": true,
    "political_content_nuanced": true,
    "violence_level": "战争场面描写详实但不渲染血腥"
  }
}
