  "customRules": [
    {
      "id": "rule-genre-ah-01",
      "description": "架空历史：禁止穿越者无挫折式碾压土著，穿越初期须有3-5章展示认知磨合与生存压力",
      "enforcement": "warning",
      "genre": "架空历史",
      "example": "穿越者第一天就用现代知识碾压土著学者，毫无文化适应过程"
    },
    {
      "id": "rule-genre-ah-02",
      "description": "架空历史：权力/地位的每次提升必须对应同量级的代价或敌人升级，禁止种田流无挫折线性升级",
      "enforcement": "warning",
      "genre": "架空历史",
      "example": "主角三个月内从小兵升至将军，权力提升无对等代价"
    },
    {
      "id": "rule-genre-ah-03",
      "description": "架空历史：每章最多引入1个新世界观设定概念，须通过情节和冲突自然揭示",
      "enforcement": "warning",
      "genre": "架空历史",
      "example": "单章引入灵根、炼丹、阵法、宗门四个世界观设定"
    },
    {
      "id": "rule-genre-ah-04",
      "description": "架空历史：反派须有独立行为逻辑，禁止皇帝/贵族看一眼就赏识主角、女性角色一见面对穿越者有好感",
      "enforcement": "warning",
      "genre": "架空历史",
      "example": "皇帝第一次见主角就大为赏识，未经任何考验即授高官"
    },
    {
      "id": "rule-genre-ow-01",
      "description": "异世大陆：灵能/魔法体系必须有明确边界、代价和上限，禁止无代价的魔法体系",
      "enforcement": "warning",
      "genre": "异世大陆",
      "example": "主角的魔法可以无限使用，无魔力消耗也无代价"
    },
    {
      "id": "rule-genre-ow-02",
      "description": "异世大陆：禁止异世界文化等同于中世纪欧洲翻版，异世界种族须各自独立演化而非人类换皮",
      "enforcement": "warning",
      "genre": "异世大陆",
      "example": "精灵族文化完全等同于中世纪法国，无独立演化痕迹"
    },
    {
      "id": "rule-genre-ow-03",
      "description": "异世大陆：修炼突破须伴随认知突破或道德抉择，不能仅靠天材地宝堆砌修为",
      "enforcement": "warning",
      "genre": "异世大陆",
      "example": "主角靠吃掉一颗千年灵芝直接从筑基跳到元婴"
    },
    {
      "id": "rule-genre-ow-04",
      "description": "异世大陆：新地图/位面的发现节奏应为每卷1-2个，每个需充分展开；每个揭开的谜底应引出更大的谜题",
      "enforcement": "warning",
      "genre": "异世大陆",
      "example": "一卷内连续发现五个新大陆，每个只用半章就跳过"
    },
    {
      "id": "rule-genre-war-01",
      "description": "战争史诗：每场战役至少展示3个层级视角（指挥决策层、基层官兵、后方民众），战争不得成为主角个人秀背景板",
      "enforcement": "warning",
      "genre": "战争史诗",
      "example": "整场战役只描写将军视角，士兵和民众完全缺席"
    },
    {
      "id": "rule-genre-war-02",
      "description": "战争史诗：军事描写须包含后勤、情报、士气等完整要素，禁止战术简化为'一声令下敌人溃败'",
      "enforcement": "warning",
      "genre": "战争史诗",
      "example": "'一声令下，大军掩杀过去，敌人溃败'——无后勤、无战术"
    },
    {
      "id": "rule-genre-war-03",
      "description": "战争史诗：战争须展示真实代价，每场胜利后须有新困难出现，每场失败后须有具体教训转化为战斗力",
      "enforcement": "warning",
      "genre": "战争史诗",
      "example": "主角连胜十场战役，每场后国家立即更强，无代价"
    },
    {
      "id": "rule-genre-war-04",
      "description": "战争史诗：每30章至少1场完整战役描写，战役间隔用于恢复、建设和政治博弈",
      "enforcement": "warning",
      "genre": "战争史诗",
      "example": "连续40章无一场完整战役，全是日常和政治博弈"
    },
    {
      "id": "rule-genre-tm-01",
      "description": "穿越：禁止穿越者心理适应期为零，须展示身份焦虑和认知融合的阶段性过程",
      "enforcement": "warning",
      "genre": "穿越",
      "example": "穿越者落地后立刻适应新世界，毫无乡愁或身份困惑"
    },
    {
      "id": "rule-genre-tm-02",
      "description": "穿越：金手指每次升级须对应主角思想认知的一次跃升，金手指须有明确边界、代价和成长曲线",
      "enforcement": "warning",
      "genre": "穿越",
      "example": "金手指从lv1直升lv10，主角心境毫无变化"
    },
    {
      "id": "rule-genre-tm-03",
      "description": "穿越：现代知识在异世界的应用须展示完整试错过程，每20章最多引入1项核心应用；禁止语言问题完全被忽略",
      "enforcement": "warning",
      "genre": "穿越",
      "example": "穿越者用初中物理知识造出蒸汽机，一次试错就成功且语言无碍"
    },
    {
      "id": "rule-genre-tm-04",
      "description": "穿越：每10章至少1段主角对自我身份的反思与挣扎",
      "enforcement": "warning",
      "genre": "穿越",
      "example": "连续15章主角忙于升级打怪，对前世无任何回忆或反思"
    },
    {
      "id": "rule-genre-pf-01",
      "description": "政治幻想：政治理念须从具体社会矛盾中自然生长，禁止空降理论体系或用现代政治话语直接套用异世界语境",
      "enforcement": "warning",
      "genre": "政治幻想",
      "example": "在一个封建农耕社会直接提出马克思主义阶级斗争理论"
    },
    {
      "id": "rule-genre-pf-02",
      "description": "政治幻想：革命组织的建设、分裂、团结须有真实过程，禁止群众觉醒整齐划一和群众无条件跟随主角",
      "enforcement": "warning",
      "genre": "政治幻想",
      "example": "全体农民在同一天觉醒，整齐划一地加入主角的革命组织"
    },
    {
      "id": "rule-genre-pf-03",
      "description": "政治幻想：全书至少3次不同思想路线的实质性辩论，不可简化为正邪对立；政治对手须有独立行为逻辑",
      "enforcement": "warning",
      "genre": "政治幻想",
      "example": "全书只有主角vs反派一种政治对立，无第三种思想路线"
    },
    {
      "id": "rule-genre-pf-04",
      "description": "政治幻想：核心政治思想的形成须经历至少4个阶段（萌芽-实践-挫败-成熟）；每10章至少1次与底层群众的深度交流",
      "enforcement": "warning",
      "genre": "政治幻想",
      "example": "主角的政治思想从第一章就完全成熟，全书无变化"
    },
    {
      "id": "rule-integrity-01",
      "description": "灵能守恒：任何灵能运用的描写必须在前后章节有能量来源和去向的说明",
      "enforcement": "warning",
      "example": "主角连续释放三个大招，从未交代灵能来源，也未出现消耗感"
    },
    {
      "id": "rule-integrity-02",
      "description": "知识对应：任何新灵能能力的出现必须对应之前建立的知识积累",
      "enforcement": "warning",
      "example": "主角突然掌握空间撕裂术，但此前从未学习过空间类知识"
    },
    {
      "id": "rule-integrity-03",
      "description": "殖民逻辑：殖民体系的运作必须在经济、技术、制度三个层面同时展现，不能简化为纯军事压迫",
      "enforcement": "warning",
      "example": "殖民统治被描写为纯粹的军事占领，无视经济剥削和制度控制"
    },
    {
      "id": "rule-integrity-04",
      "description": "阶级流动：所有跨阶级行为必须展示结构性阻力和代价",
      "enforcement": "warning",
      "example": "平民主角靠个人能力直接进入贵族顶层，无任何结构性障碍"
    },
    {
      "id": "rule-integrity-05",
      "description": "参考坐标_毛泽东选集：引用或化用的军事/政治思想的每一次应用必须对应具体的战场或社会实际条件，不能空降理论",
      "enforcement": "warning",
      "example": "在完全不同的世界环境下，原封不动引用'论持久战'的具体战术"
    },
