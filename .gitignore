# OS / Editor
.DS_Store
*.swp
*.swo
*~

# Dependencies
node_modules/
.env
.env.local

# Python
__pycache__/
*.pyc
*.pyo

# IDE
.idea/
.vscode/

# Backup files
*.bak

# Round artifacts — entire real rounds are test-run state, regenerated each run.
# Only the TEMPLATE is tracked. Pattern matches round-NNN-YYYY-MM-DD only.
tests/rounds/round-[0-9][0-9][0-9]-[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Per-skill test outputs (regenerated per test run, not source)
tests/tiers/t1-skill/*/bug-hunt/bug-hunt-report.md
tests/tiers/t1-skill/*/clean/clean-report.md
tests/tiers/t1-skill/*/generative/generative-report.md

# P-1.A additions (Python tooling artifacts)

# Pytest
.pytest_cache/
tests/coverage/

# Type checkers
.mypy_cache/
.ruff_cache/
.basedpyright_cache/

# Coverage
.coverage
coverage.xml
htmlcov/

# Build artifacts
*.egg-info/
dist/
build/

# Docs (auto-generated by mkdocstrings)
docs/api/
site/

# SBOM and mutation testing
sbom.cdx.json
!tests/coverage/.gitkeep

# Worktrees (local isolated workspaces)
.worktrees/
mutants/
