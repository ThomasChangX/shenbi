# Backup files
*.bak

# Round artifacts — entire real rounds are test-run state, regenerated each run.
# Only the TEMPLATE is tracked. Pattern matches round-NNN-YYYY-MM-DD only.
tests/rounds/round-[0-9][0-9][0-9]-[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Per-skill test outputs (regenerated per test run, not source)
tests/tiers/t1-skill/*/bug-hunt/bug-hunt-report.md
tests/tiers/t1-skill/*/clean/clean-report.md
tests/tiers/t1-skill/*/generative/generative-report.md
