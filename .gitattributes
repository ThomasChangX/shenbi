# Enforce LF line endings on all text files across all platforms.
# Critical for cross-platform CI: G0.14 calibration hash uses read_bytes(),
# so CRLF conversion on Windows would change the hash and fail the gate.
* text=auto eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.lock binary
